# ===========================================================================
# SHIKKHA PLATFORM — .env.example
# ===========================================================================
# HOW TO USE:
#   1. Copy this file to .env.local
#   2. Fill in each blank value by following ../ENV_SETUP_GUIDE.md.pdf
#   3. NEVER commit .env.local to git (already in .gitignore)
#   4. Use SEPARATE values for development vs production environments.
# ===========================================================================


# ---------------------------------------------------------------------------
# CORE — Next.js & App Config
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Shikkha Platform"
NEXT_PUBLIC_APP_SHORT_NAME="Shikkha"
NODE_ENV=development

# Generate with: openssl rand -base64 32
JWT_SECRET=

# Generate with: openssl rand -hex 32
SESSION_SECRET=


# ---------------------------------------------------------------------------
# SUPABASE — Database + Auth + Storage + Realtime
# Signup: https://supabase.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=


# ---------------------------------------------------------------------------
# VERCEL — Hosting (auto-filled in prod)
# ---------------------------------------------------------------------------
VERCEL_URL=
VERCEL_ENV=development


# ---------------------------------------------------------------------------
# EMAIL — Resend
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@shikkha.app
RESEND_FROM_NAME="Shikkha Platform"
RESEND_REPLY_TO=support@shikkha.app


# ---------------------------------------------------------------------------
# SMS — SSL Wireless (primary BD SMS provider)
# ---------------------------------------------------------------------------
SSL_SMS_API_TOKEN=
SSL_SMS_SID=
SSL_SMS_URL=https://smsplus.sslwireless.com/api/v3/send-sms
SSL_SMS_SENDER_ID=

# SMS — Alpha SMS (fallback)
ALPHA_SMS_API_KEY=
ALPHA_SMS_SENDER_ID=
ALPHA_SMS_URL=https://api.sms.net.bd/sendsms

# SMS — BulkSMSBD (secondary fallback)
BULKSMS_BD_API_KEY=
BULKSMS_BD_SENDER_ID=


# ---------------------------------------------------------------------------
# PAYMENT — SSLCommerz (covers all BD cards + all MFS)
# ---------------------------------------------------------------------------
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=true
SSLCOMMERZ_SUCCESS_URL=http://localhost:3000/api/payment/sslcommerz/success
SSLCOMMERZ_FAIL_URL=http://localhost:3000/api/payment/sslcommerz/fail
SSLCOMMERZ_CANCEL_URL=http://localhost:3000/api/payment/sslcommerz/cancel
SSLCOMMERZ_IPN_URL=http://localhost:3000/api/payment/sslcommerz/ipn

# PAYMENT — bKash direct (lower fee than SSLCommerz)
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_CALLBACK_URL=http://localhost:3000/api/payment/bkash/callback

# PAYMENT — Nagad direct (optional, lowest fee)
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PG_PUBLIC_KEY=
NAGAD_MERCHANT_PRIVATE_KEY=
NAGAD_BASE_URL=https://api.mynagad.com/api/dfs
NAGAD_CALLBACK_URL=http://localhost:3000/api/payment/nagad/callback

# PAYMENT — Stripe (ONLY if serving international schools)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=


# ---------------------------------------------------------------------------
# PUSH NOTIFICATIONS — Firebase Cloud Messaging (FREE unlimited)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=


# ---------------------------------------------------------------------------
# IMAGE STORAGE — Cloudinary (optional, Supabase Storage is default)
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=


# ---------------------------------------------------------------------------
# WHATSAPP — Meta Cloud API
# ---------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=


# ---------------------------------------------------------------------------
# AI — Anthropic Claude
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# AI — OpenAI (backup/fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini


# ---------------------------------------------------------------------------
# ERROR TRACKING — Sentry
# ---------------------------------------------------------------------------
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=shikkha-platform


# ---------------------------------------------------------------------------
# ANALYTICS — PostHog
# ---------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# ---------------------------------------------------------------------------
# CACHING + RATE LIMIT — Upstash Redis
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ---------------------------------------------------------------------------
# MAPS — Google Maps
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=


# ---------------------------------------------------------------------------
# CRON / SCHEDULED JOBS
# ---------------------------------------------------------------------------
CRON_SECRET=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=


# ---------------------------------------------------------------------------
# FILE UPLOAD
# ---------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
MAX_PROFILE_IMAGE_SIZE_MB=2


# ---------------------------------------------------------------------------
# FEATURE FLAGS
# ---------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_AI_FEATURES=false
NEXT_PUBLIC_ENABLE_MADRASA_MODULE=true
NEXT_PUBLIC_ENABLE_WHATSAPP=false
NEXT_PUBLIC_ENABLE_BIOMETRIC=false
NEXT_PUBLIC_ENABLE_LMS=false


# ---------------------------------------------------------------------------
# SUPER ADMIN — bootstrap first login (remove after first deploy)
# ---------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_INITIAL_PASSWORD=
